generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                                                String            @id @default(cuid())
  email                                             String            @unique
  password                                          String
  avatar                                            String?
  role                                              Role              @default(USER)
  createdAt                                         DateTime          @default(now())
  updatedAt                                         DateTime          @updatedAt
  emailVerified                                     DateTime?
  firstName                                         String
  lastName                                          String
  resetToken                                        String?
  resetTokenExpiry                                  DateTime?
  accounts                                          Account[]
  activities                                        Activity[]
  CompanySettings_CompanySettings_createdByIdToUser CompanySettings[] @relation("CompanySettings_createdByIdToUser")
  CompanySettings_CompanySettings_updatedByIdToUser CompanySettings[] @relation("CompanySettings_updatedByIdToUser")
  CompanySettings_CompanySettings_userIdToUser      CompanySettings?  @relation("CompanySettings_userIdToUser")
  Receipt_Receipt_createdByIdToUser                 Receipt[]         @relation("Receipt_createdByIdToUser")
  Receipt_Receipt_updatedByIdToUser                 Receipt[]         @relation("Receipt_updatedByIdToUser")
  Receipt_Receipt_userIdToUser                      Receipt[]         @relation("Receipt_userIdToUser")
  sessions                                          Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  expires      DateTime
  sessionToken String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Banner {
  id                 String        @id @default(cuid())
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  title              String
  description        String?
  imageUrl           String
  cloudinaryPublicId String?
  order              Int?
  isDeleted          Boolean @default(false)
  deletedAt          DateTime?


}

// ------------------------
// ABOUTBANNER MODEL
// ------------------------
model AboutBanner {
  id String @id @default(cuid())
  title String
  subtitle String
  image String // Cloudinary URL
  
  isDeleted Boolean @default(false)
  deletedAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ------------------------
// EVENTSBANNER MODEL
// ------------------------
model EventsBanner {
  id String @id @default(cuid())
  title String
  subtitle String
  image String // Cloudinary URL
  
  isDeleted Boolean @default(false)
  deletedAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ------------------------
// BLOGSBANNER MODEL
// ------------------------
model BlogsBanner {
  id String @id @default(cuid())
  title String
  subtitle String
  image String // Cloudinary URL
  
  isDeleted Boolean @default(false)
  deletedAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanySettings {
  id                                     String   @id
  createdAt                              DateTime @default(now())
  updatedAt                              DateTime
  userId                                 String   @unique
  name                                   String
  email                                  String
  logo                                   String?
  contacts                               Json
  createdById                            String?
  updatedById                            String?
  User_CompanySettings_createdByIdToUser User?    @relation("CompanySettings_createdByIdToUser", fields: [createdById], references: [id])
  User_CompanySettings_updatedByIdToUser User?    @relation("CompanySettings_updatedByIdToUser", fields: [updatedById], references: [id])
  User_CompanySettings_userIdToUser      User     @relation("CompanySettings_userIdToUser", fields: [userId], references: [id], onDelete: Cascade)
}

model Receipt {
  id                             String    @id
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime
  customerOrganization           String
  customerName                   String?
  customerEmail                  String?
  clientContacts                 Json?
  additionalNames                Json?
  additionalEmails               Json?
  projectName                    String
  serviceType                    String
  projectStartDate               DateTime
  projectEndDate                 DateTime
  description                    String?
  projectTotal                   Float
  amountPaid                     Float
  remainingBalance               Float
  currency                       String
  paymentMethod                  String
  bankName                       String?
  bankAccountNumber              String?
  cardNumber                     String?
  mobileMoneyProvider            String?
  mobileNumber                   String?
  countryCode                    String?
  companyName                    String?
  companyEmail                   String?
  companyLogo                    String?
  companyContacts                Json?
  userId                         String
  createdById                    String?
  updatedById                    String?
  deletedAt                      DateTime?
  User_Receipt_createdByIdToUser User?     @relation("Receipt_createdByIdToUser", fields: [createdById], references: [id])
  User_Receipt_updatedByIdToUser User?     @relation("Receipt_updatedByIdToUser", fields: [updatedById], references: [id])
  User_Receipt_userIdToUser      User      @relation("Receipt_userIdToUser", fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  USER
}



// ------------------------
// FOUNDER MODEL
// ------------------------
model Founder {
  id String @id @default(cuid())
  name String
  role String
  image String // Cloudinary URL
  bio String
  order Int @default(0)
  
  isDeleted Boolean @default(false)
  deletedAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ------------------------
// WORK MODEL (Our Work Gallery)
// ------------------------
model Work {
  id String @id @default(cuid())
  caption String
  image String // Cloudinary URL
  order Int @default(0)
  
  isDeleted Boolean @default(false)
  deletedAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// ------------------------
// EVENT MODEL
// ------------------------
model Event {
  id String @id @default(cuid())
  title String
  description String
  image String // Cloudinary URL
  date String
  order Int @default(0)
  
  isDeleted Boolean @default(false)
  deletedAt DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
